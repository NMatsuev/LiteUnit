<Window x:Class="TestsRunner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestsRunner" 
        xmlns:converters="clr-namespace:TestsRunner.Converters"
        xmlns:viewModels="clr-namespace:TestsRunner.ViewModels"
        mc:Ignorable="d"
        Title="Test Runner" Height="450" Width="800"
        Background="#F5F0FF">

    <Window.Resources>
        <!-- Цвета приложения -->
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8A2BE2"/>
        <SolidColorBrush x:Key="LightPurple" Color="#E6D9FF"/>
        <SolidColorBrush x:Key="VeryLightPurple" Color="#F0E6FF"/>
        <SolidColorBrush x:Key="White" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DarkPurple" Color="#4B0082"/>

        <!-- РЕГИСТРИРУЕМ КОНВЕРТЕР -->
        <converters:StatusToImageConverter x:Key="StatusToImageConverter"/>

        <!-- Стиль для кнопок -->
        <Style x:Key="PurpleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,8"/>
            <Setter Property="MinWidth" Value="120"/>
            <!-- Минимальная ширина -->
            <Setter Property="MinHeight" Value="40"/>
            <!-- Минимальная высота -->
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DarkPurple}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон для отображения элементов дерева с иконками -->
        <HierarchicalDataTemplate DataType="{x:Type viewModels:TreeViewItemViewModel}"
                          ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <!-- Картинка статуса -->
                <Image Source="{Binding Status, Converter={StaticResource StatusToImageConverter}}" 
               Width="16" 
               Height="16"
               Margin="0,0,5,0"/>

                <!-- Текст элемента -->
                <TextBlock Text="{Binding DisplayName}" 
                  VerticalAlignment="Center"
                  FontSize="13"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Стиль для TreeView -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource White}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightPurple}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <!-- Стиль для элемента TreeView -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource LightPurple}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource VeryLightPurple}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <!-- Верхняя панель с кнопками -->
        <Border Grid.Row="0" 
        Background="{StaticResource White}" 
        Padding="15,10"
        BorderBrush="{StaticResource LightPurple}"
        BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Загрузить сборку" 
                Style="{StaticResource PurpleButtonStyle}"
                Click="btnLoadAssembly_Click"
                ToolTip="Загрузить новую тестовую сборку"/>

                <Button Content="Удалить сборку" 
                Style="{StaticResource PurpleButtonStyle}"
                Click="btnDeleteAssembly_Click"
                ToolTip="Удалить выбранную сборку"/>

                <Button Content="Запуск тестов" 
                Style="{StaticResource PurpleButtonStyle}"
                Click="btnRunSelectedTests_Click"
                ToolTip="Запустить выбранные тесты"/>

                <!-- Разделитель -->
                <Rectangle Width="2" 
                  Fill="{StaticResource LightPurple}" 
                  Margin="20,0"/>

                <!-- Информация о количестве выбранных тестов -->
                <TextBlock x:Name="txtSelectedCount" 
                  Text="Выбрано: 0 тестов" 
                  VerticalAlignment="Center"
                  Foreground="{StaticResource PrimaryPurple}"
                  FontWeight="SemiBold"
                  Margin="5,0"/>
            </StackPanel>
        </Border>

        <!-- Область с деревом тестов -->
        <Grid Grid.Row="1" Background="{StaticResource VeryLightPurple}">
            <TreeView x:Name="TestTreeView"
              ItemsSource="{Binding TestAssemblies}"
              Background="{StaticResource White}"
              BorderBrush="{StaticResource LightPurple}"
              BorderThickness="1"
              Margin="10"
              SelectedItemChanged="TestTreeView_SelectedItemChanged"/>
        </Grid>
    </Grid>
</Window>