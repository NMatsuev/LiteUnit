<Window x:Class="TestsRunner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:TestsRunner.Converters"
        xmlns:viewModels="clr-namespace:TestsRunner.ViewModels.Implementations"
        mc:Ignorable="d"
        Title="Test Runner" Height="450" Width="800"
        Background="#F5F0FF">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryPurple" Color="#8A2BE2"/>
        <SolidColorBrush x:Key="LightPurple" Color="#E6D9FF"/>
        <SolidColorBrush x:Key="VeryLightPurple" Color="#F0E6FF"/>
        <SolidColorBrush x:Key="White" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DarkPurple" Color="#4B0082"/>

        <converters:StatusToImageConverter x:Key="StatusToImageConverter"/>

        <Style x:Key="PurpleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPurple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,8"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DarkPurple}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Шаблон для метода (может содержать дочерние TestCase) -->
        <HierarchicalDataTemplate DataType="{x:Type viewModels:MethodViewModel}" 
                          ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2" ToolTip="{Binding ToolTip}">
                <Image Source="{Binding Status, Converter={StaticResource StatusToImageConverter}}" 
               Width="16" Height="16" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding DisplayString}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ToolTip}" 
                  Margin="10,0,0,0" 
                  Foreground="Gray" 
                  FontSize="11" 
                  VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Шаблон для TestCase (для параметризованных тестов) -->
        <DataTemplate DataType="{x:Type viewModels:TestCaseViewModel}">
            <StackPanel Orientation="Horizontal" Margin="2,2,2,2" ToolTip="{Binding ToolTip}">
                <Image Source="{Binding Status, Converter={StaticResource StatusToImageConverter}}" 
               Width="14" Height="14" Margin="20,0,5,0"/>
                <TextBlock Text="{Binding DisplayName}" 
                  VerticalAlignment="Center" 
                  FontStyle="Italic"
                  Foreground="#4B0082"/>
                <TextBlock Text="{Binding ToolTip}" 
                  Margin="10,0,0,0" 
                  Foreground="Gray" 
                  FontSize="11" 
                  VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- Шаблон для класса -->
        <HierarchicalDataTemplate DataType="{x:Type viewModels:ClassViewModel}" 
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <Image Source="{Binding Status, Converter={StaticResource StatusToImageConverter}}" 
                       Width="16" Height="16" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Шаблон для сборки -->
        <HierarchicalDataTemplate DataType="{x:Type viewModels:AssemblyViewModel}" 
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2">
                <Image Source="{Binding Status, Converter={StaticResource StatusToImageConverter}}" 
                       Width="16" Height="16" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="#4B0082"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Стиль для TreeView -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource White}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightPurple}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <!-- Стиль для элемента TreeView -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource LightPurple}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource VeryLightPurple}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
        Background="{StaticResource White}" 
        Padding="15,10"
        BorderBrush="{StaticResource LightPurple}"
        BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Загрузить сборку" 
                            Style="{StaticResource PurpleButtonStyle}"
                            Command="{Binding LoadAssemblyCommand}"
                            ToolTip="Загрузить новую тестовую сборку"/>

                    <Button Content="Удалить сборку" 
                            Style="{StaticResource PurpleButtonStyle}"
                            Command="{Binding DeleteAssemblyCommand}"
                            ToolTip="Удалить выбранную сборку"/>

                    <Button Content="Запуск тестов" 
                            Style="{StaticResource PurpleButtonStyle}"
                            Command="{Binding RunSelectedTestsCommand}"
                            ToolTip="Запустить выбранные тесты"/>
                </StackPanel>

                <!-- Статистика справа -->
                <StackPanel Grid.Column="2" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center"
                    Margin="10,0">

                    <!-- Разделитель -->
                    <Rectangle Width="2" 
                      Fill="{StaticResource LightPurple}" 
                      Margin="0,0,15,0"/>

                    <!-- Общая статистика -->
                    <Border Background="{StaticResource VeryLightPurple}"
                    CornerRadius="5"
                    Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                            <!-- Всего тестов -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <TextBlock Text="Всего: "
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource DarkPurple}"
                                  FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalTests}"  
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource DarkPurple}"
                                  FontWeight="Bold"
                                  FontSize="16"
                                  Margin="3,0"/>
                            </StackPanel>

                            <!-- Вертикальный разделитель -->
                            <Rectangle Width="1" 
                              Fill="{StaticResource LightPurple}" 
                              Margin="0,2,15,2"/>

                            <!-- Пройдено -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Image Source="../Images/test_passed.png" 
                       Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding PassedTests}" 
                                  VerticalAlignment="Center"
                                  Foreground="Green"
                                  FontWeight="Bold"
                                  FontSize="16"
                                  Margin="3,0"/>
                            </StackPanel>

                            <!-- Не пройдено -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Image Source="../Images/test_failed.png" 
                       Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding FailedTests}" 
                                  VerticalAlignment="Center"
                                  Foreground="Red"
                                  FontWeight="Bold"
                                  FontSize="16"
                                  Margin="3,0"/>
                            </StackPanel>

                            <!-- Пропущено -->
                            <StackPanel Orientation="Horizontal">
                                <Image Source="../Images/test_none.png" 
                       Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding SkippedTests}"
                                  VerticalAlignment="Center"
                                  Foreground="Blue"
                                  FontWeight="Bold"
                                  FontSize="16"
                                  Margin="3,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Информация о выбранных тестах -->
                    <Border Background="{StaticResource LightPurple}"
                     CornerRadius="5"
                     Padding="15,5"
                     Margin="10,0,0,0">
                        <TextBlock Text="{Binding SelectedCountText}" 
                         VerticalAlignment="Center"
                         Foreground="{StaticResource DarkPurple}"
                         FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Область с деревом тестов -->
        <Grid Grid.Row="1" Background="#F0E6FF">
            <TreeView x:Name="TestTreeView"
                      ItemsSource="{Binding TestAssemblies}"
                      SelectedItemChanged="TestTreeView_SelectedItemChanged"
                      Background="White"
                      BorderBrush="#E6D9FF"
                      BorderThickness="1"
                      Margin="10"/>
        </Grid>
    </Grid>
</Window>